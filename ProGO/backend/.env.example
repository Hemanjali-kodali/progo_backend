# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/parent_student_chatbot

# JWT Secret for Authentication
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# Session Secret
SESSION_SECRET=your_session_secret_key_here_change_in_production

# Session Timeout (in milliseconds) - Default: 30 minutes
SESSION_TIMEOUT=1800000

# Admin Configuration
ADMIN_KEY=admin-secret-key-change-this

# CORS Configuration
# Comma-separated list is supported in production
CLIENT_URL=http://localhost:3000

# ML Model Configuration
# Training iterations for Intent Classifier
ML_INTENT_ITERATIONS=2000

# Training epochs for Performance Predictor
ML_PERFORMANCE_EPOCHS=100

# Sample data size for training
ML_TRAINING_DATA_SIZE=1000

# OTP / Email Configuration (Forgot Password)
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=your_email@gmail.com
OTP_TTL_MINUTES=5

# WhatsApp Cloud API (Meta)
WHATSAPP_VERIFY_TOKEN=choose_a_random_webhook_verify_token
WHATSAPP_ACCESS_TOKEN=your_meta_whatsapp_permanent_access_token
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_business_phone_number_id
WHATSAPP_GRAPH_API_VERSION=v21.0
